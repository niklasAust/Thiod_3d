    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;9;-1024,192;Half;False;Constant;_Float1;Float
    1;1;0;Create;True;0;0;0;False;0;False;9;0;0;0;0;1;FLOAT;0\nNode;AmplifyShaderEditor.CustomExpressionNode,
