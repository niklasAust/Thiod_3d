    float2 i = floor(p)@$    float2 f = frac(p)@$    float2 u = f * f * (3.0 - 2.0
    * f)@ // smoothstep$$    float a = hash(i)@$    float b = hash(i + float2(1.0,
    0.0))@$    float c = hash(i + float2(0.0, 1.0))@$    float d = hash(i + float2(1.0,
    1.0))@$$    return lerp(lerp(a, b, u.x), lerp(c, d, u.x), u.y)@;1;Create;1;True;p;FLOAT2;0,0;In;;Inherit;False;SimpleNoise2D;False;False;1;2;;False;1;0;FLOAT2;0,0;False;1;FLOAT;0\nNode;AmplifyShaderEditor.CustomExpressionNode,
