    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;299;3584,1344;Inherit;False;Proxy
    Mask;1;7;False;1;0;FLOAT;0;False;1;FLOAT;0\nNode;AmplifyShaderEditor.FunctionInput,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;294;3584,0;Inherit;False;Terrain
    UV;4;5;False;1;0;FLOAT4;0,0,0,0;False;1;FLOAT4;0\nNode;AmplifyShaderEditor.CustomExpressionNode,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;238;4096,384;Float;False;half2
    UV = WorldPosition.xz * Coords.xy + Coords.zw@$$half4 tex = SAMPLE_TEXTURE2D(
    Texture, Sampler, UV)@$$return tex@;4;Create;4;True;Texture;SAMPLER2D;;In;;Float;False;True;Sampler;SAMPLERSTATE;;In;;Float;False;True;Coords;FLOAT4;0,0,0,0;In;;Float;False;True;WorldPosition;FLOAT3;0,0,0;In;;Float;False;SamplePlanar2D;False;False;1;237;;False;4;0;SAMPLER2D;;False;1;SAMPLERSTATE;;False;2;FLOAT4;0,0,0,0;False;3;FLOAT3;0,0,0;False;1;FLOAT4;0\nNode;AmplifyShaderEditor.CustomExpressionNode,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;236;3552,-640;Float;False;half2
    vertex1, vertex2, vertex3@$$// Scaling of the input$half2 uv = UV * 3.464@ //
    2 * sqrt (3)$$// Skew input space into simplex triangle grid$const float2x2 gridToSkewedGrid
    = float2x2( 1.0, 0.0, -0.57735027, 1.15470054 )@$half2 skewedCoord = mul( gridToSkewedGrid,
    uv )@$$// Compute local triangle vertex IDs and local barycentric coordinates$int2
    baseId = int2( floor( skewedCoord ) )@$half3 temp = half3( frac( skewedCoord
    ), 0 )@$temp.z = 1.0 - temp.x - temp.y@$if ( temp.z > 0.0 )${$\tW1 = temp.z@$\tW2
    = temp.y@$\tW3 = temp.x@$\tvertex1 = baseId@$\tvertex2 = baseId + int2( 0, 1
    )@$\tvertex3 = baseId + int2( 1, 0 )@$}$else${$\tW1 = -temp.z@$\tW2 = 1.0 - temp.y@$\tW3
    = 1.0 - temp.x@$\tvertex1 = baseId + int2( 1, 1 )@$\tvertex2 = baseId + int2(
    1, 0 )@$\tvertex3 = baseId + int2( 0, 1 )@$}$$UV1 = UV + ComputeStochasticHash22(vertex1)@$UV2
    = UV + ComputeStochasticHash22(vertex2)@$UV3 = UV + ComputeStochasticHash22(vertex3)@$return@;8;Create;7;True;UV;FLOAT2;0,0;In;;Float;False;True;UV1;FLOAT2;0,0;Out;;Float;False;True;UV2;FLOAT2;0,0;Out;;Float;False;True;UV3;FLOAT2;0,0;Out;;Float;False;True;W1;FLOAT;0;Out;;Float;False;True;W2;FLOAT;0;Out;;Float;False;True;W3;FLOAT;0;Out;;Float;False;ComputeStochasticCoords;False;False;1;293;;False;8;0;FLOAT;0;False;1;FLOAT2;0,0;False;2;FLOAT2;0,0;False;3;FLOAT2;0,0;False;4;FLOAT2;0,0;False;5;FLOAT;0;False;6;FLOAT;0;False;7;FLOAT;0;False;7;FLOAT;0;FLOAT2;3;FLOAT2;4;FLOAT2;5;FLOAT;6;FLOAT;7;FLOAT;8\nNode;AmplifyShaderEditor.CustomExpressionNode,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;293;3840,-640;Float;False;float3
    p3 = frac(float3(p.xyx) * float3(.1031, .1030, .0973))@$p3 += dot(p3, p3.yzx+33.33)@$return
    frac((p3.xx+p3.yz)*p3.zy)@;2;Create;1;True;p;FLOAT2;0,0;In;;Float;False;ComputeStochasticHash22;False;False;0;;False;1;0;FLOAT2;0,0;False;1;FLOAT2;0\nNode;AmplifyShaderEditor.CustomExpressionNode,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;246;4096,544;Float;False;half2
    ZX, ZY, XY@$$ComputeWorldCoords(Coords, WorldPosition, ZX, ZY, XY)@$$half T1,
    T2, T3@$$ComputeTriplanarWeights(WorldNormal, T1, T2, T3)@$$half4 tex1 = SAMPLE_TEXTURE2D(
    Texture, Sampler, ZX)@$half4 tex2 = SAMPLE_TEXTURE2D( Texture, Sampler, ZY)@$half4
    tex3 = SAMPLE_TEXTURE2D( Texture, Sampler, XY)@$$return tex1 * T1 + tex2 * T2
    + tex3 * T3@;4;Create;5;True;Texture;SAMPLER2D;;In;;Float;False;True;Sampler;SAMPLERSTATE;;In;;Float;False;True;Coords;FLOAT4;0,0,0,0;In;;Float;False;True;WorldPosition;FLOAT3;0,0,0;In;;Float;False;True;WorldNormal;FLOAT3;0,0,0;In;;Half;False;SamplePlanar3D;False;False;2;237;120;;False;5;0;SAMPLER2D;;False;1;SAMPLERSTATE;;False;2;FLOAT4;0,0,0,0;False;3;FLOAT3;0,0,0;False;4;FLOAT3;0,0,0;False;1;FLOAT4;0\nNode;AmplifyShaderEditor.CustomExpressionNode,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;234;4096,736;Float;False;half2
    UV = WorldPosition.xz * Coords.xy + Coords.zw@$$half4 output@$half2 UV1, UV2,
    UV3@$half W1, W2, W3@$float4 tex1, tex2, tex3@$$//UNITY_BRANCH$//if (ProxyMask
    < 0.5)$//{$\tComputeStochasticCoords(UV, UV1, UV2, UV3, W1, W2, W3 )@$//}$$float2
    ddxUV = ddx(UV)@$float2 ddyUV = ddy(UV)@$$UNITY_BRANCH$if (ProxyMask < 0.5)${$\ttex1
    = SAMPLE_TEXTURE2D_GRAD( Texture, Sampler, UV1, ddxUV, ddyUV)@$\ttex2 = SAMPLE_TEXTURE2D_GRAD(
    Texture, Sampler, UV2, ddxUV, ddyUV)@$\ttex3 = SAMPLE_TEXTURE2D_GRAD( Texture,
    Sampler, UV3, ddxUV, ddyUV)@$\t$\toutput = tex1 * W1 + tex2 * W2 + tex3 * W3@$}$else${$\t//output
    = SAMPLE_TEXTURE2D( Proxy, Sampler, ProxyUV)@$\toutput = half4(0,0,0,0)@$}$$return
    output@;4;Create;7;True;Texture;SAMPLER2D;0,0;In;;Float;False;True;Sampler;SAMPLERSTATE;0,0;In;;Float;False;True;Coords;FLOAT4;0,0,0,0;In;;Float;False;True;WorldPosition;FLOAT3;0,0,0;In;;Float;False;True;Proxy;SAMPLER2D;;In;;Float;False;True;ProxyMask;FLOAT;0;In;;Half;False;True;ProxyUV;FLOAT2;0,0;In;;Float;False;SampleStochastic2DTerrain;False;False;2;237;236;;False;7;0;SAMPLER2D;0,0;False;1;SAMPLERSTATE;0,0;False;2;FLOAT4;0,0,0,0;False;3;FLOAT3;0,0,0;False;4;SAMPLER2D;;False;5;FLOAT;0;False;6;FLOAT2;0,0;False;1;FLOAT4;0\nNode;AmplifyShaderEditor.FunctionOutput,
