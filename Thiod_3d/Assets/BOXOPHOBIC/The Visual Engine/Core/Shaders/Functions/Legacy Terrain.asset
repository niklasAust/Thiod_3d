    = WorldPosition.xz * Coords.xx - Coords.zz@$ZY = WorldPosition.yz * Coords.yx
    - Coords.wz@ $XY = WorldPosition.xy * Coords.xy - Coords.zw@$;8;Create;5;True;Coords;FLOAT4;0,0,0,0;In;;Float;False;True;WorldPosition;FLOAT3;0,0,0;In;;Float;False;True;ZX;FLOAT2;0,0;Out;;Float;False;True;ZY;FLOAT2;0,0;Out;;Float;False;True;XY;FLOAT2;0,0;Out;;Float;False;ComputeWorldCoords;False;False;0;;False;6;0;FLOAT;0;False;1;FLOAT4;0,0,0,0;False;2;FLOAT3;0,0,0;False;3;FLOAT2;0,0;False;4;FLOAT2;0,0;False;5;FLOAT2;0,0;False;4;FLOAT;0;FLOAT2;4;FLOAT2;5;FLOAT2;6\nNode;AmplifyShaderEditor.CustomExpressionNode,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;120;3296,-640;Float;False;half3
    powNormal = abs( WorldNormal.xyz )@$half3 weights = max( powNormal * powNormal
    * powNormal * powNormal * powNormal * powNormal * powNormal * powNormal, 0.000001
    )@$weights /= ( weights.x + weights.y + weights.z ).xxx@$T1 = weights.y@$T2 =
    weights.x@$T3 = weights.z@$;8;Create;4;True;WorldNormal;FLOAT3;0,0,0;In;;Half;False;True;T1;FLOAT;0;Out;;Half;False;True;T2;FLOAT;0;Out;;Half;False;True;T3;FLOAT;0;Out;;Half;False;ComputeTriplanarWeights;False;False;0;;False;5;0;FLOAT;0;False;1;FLOAT3;0,0,0;False;2;FLOAT;0;False;3;FLOAT;0;False;4;FLOAT;0;False;4;FLOAT;0;FLOAT;3;FLOAT;4;FLOAT;5\nNode;AmplifyShaderEditor.WorldPosInputsNode,
