  m_functionInfo: "// Made with Amplify Shader Editor v1.9.9.8\n// Available at the
    Unity Asset Store - http://u3d.as/y3X \n/*ASEBEGIN\nVersion=19908\nNode;AmplifyShaderEditor.FunctionInput,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;77;-1152,256;Inherit;False;UV;2;0;False;1;0;FLOAT2;0,0;False;1;FLOAT2;0\nNode;AmplifyShaderEditor.CustomExpressionNode,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;80;-768,0;Half;False;//float2
    pixelCoords = screenUV.xy@$float2 pixelCoords = screenUV.xy * _ScreenParams.xy@$$float
    dither = frac(52.9829189 * frac( dot( pixelCoords, float2(0.06711056, 0.00583715))))@$$return
    dither@;1;Create;1;True;screenUV;FLOAT2;0,0;In;;Half;False;Noise IGN;False;False;0;;False;1;0;FLOAT2;0,0;False;1;FLOAT;0\nNode;AmplifyShaderEditor.CustomExpressionNode,
    AmplifyShaderEditor, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null;79;-768,256;Half;False;float2
    pixelCoords = screenUV.xy * _ScreenParams.xy@$$int2 pos = int2(pixelCoords) &
    3@$int index = pos.y * 4 + pos.x@$$static const float bayer[16] = {$    1.0, 
    9.0,  3.0, 11.0,$   13.0,  5.0, 15.0,  7.0,$    4.0, 12.0,  2.0, 10.0,$   16.0, 
    8.0, 14.0,  6.0$}@$$float dither = bayer[index] * (1.0 / 16.0)@$return dither@;1;Create;1;True;screenUV;FLOAT2;0,0;In;;Half;False;Noise
