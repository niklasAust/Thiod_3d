			void ComputeWorldCoords( float4 Coords, float3 PositionWS, out float2 ZY, out float2 XZ, out float2 XY )
			{
				ZY = PositionWS.zy * Coords.xy - Coords.zw; 
				XZ = PositionWS.xz * Coords.xx - Coords.zz;
