			half NoiseDither( half2 screenUV )
			{
				float2 pixelCoords = screenUV.xy * _ScreenParams.xy;
				int2 pos = int2(pixelCoords) & 3;
				int index = pos.y * 4 + pos.x;
				static const float bayer[16] = {
				    1.0,  9.0,  3.0, 11.0,
				   13.0,  5.0, 15.0,  7.0,
				    4.0, 12.0,  2.0, 10.0,
				   16.0,  8.0, 14.0,  6.0
				};
				float dither = bayer[index] * (1.0 / 16.0);
				return dither;
			}
			
			half4 mod289( half4 x )
			{
				return x - floor(x * 0.00346020761) * 289.0;
