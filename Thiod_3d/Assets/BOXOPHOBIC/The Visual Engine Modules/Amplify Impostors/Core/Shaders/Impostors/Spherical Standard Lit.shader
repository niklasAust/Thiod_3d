				    float4 o1 = frac(k3 * 0.0243902439);
				    float4 o2 = frac(k4 * 0.0243902439);
				    // Interpolate along z, then x, then y.
				    float4 o3 = lerp(o1, o2, f.z);           // f.z blends between layers.
