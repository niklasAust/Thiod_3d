			inline void SphereImpostorFragment( inout ImpostorOutput o, out float4 positionCS, out float3 positionWS, float4 frameUV, float4 viewPos, out float4 output0, out float4 output1, out float4 output2, out float4 output3, out float4 output4 )
			{
				#if defined( _USE_PARALLAX_ON )
				float4 parallaxSample = SAMPLE_TEXTURE2D_BIAS( _Normals, sampler_Normals, frameUV.xy, -1 );
				frameUV.xy = ( ( 0.5 - parallaxSample.a ) * frameUV.zw ) + frameUV.xy;
				#endif
				float4 albedoSample = SAMPLE_TEXTURE2D_BIAS( _Albedo, sampler_Albedo, frameUV.xy, _AI_TextureBias );
				o.Alpha = ( albedoSample.a - _AI_Clip );
				clip( o.Alpha );
				o.Albedo = albedoSample.rgb;
				float4 normalSample = SAMPLE_TEXTURE2D_BIAS( _Normals, sampler_Normals, frameUV.xy, _AI_TextureBias );
				float4 objectNormal = normalSample * 2 - 1;
				o.WorldNormal = normalize( mul( (float3x3)AI_ObjectToWorld, objectNormal.xyz ) );
				#if defined(UNITY_PASS_SHADOWCASTER) // Standard RP fix for deferred path
				float depth = objectNormal.w * _AI_DepthSize * 0.5 * length( AI_ObjectToWorld[ 2 ].xyz ) - 0.001;
				#else
				float depth = objectNormal.w * _AI_DepthSize * 0.5 * length( AI_ObjectToWorld[ 2 ].xyz );
				#endif
				output0 = SAMPLE_TEXTURE2D_BIAS( _Shader, sampler_Shader, frameUV.xy, _AI_TextureBias );
				output1 = SAMPLE_TEXTURE2D_BIAS( _Packed, sampler_Packed, frameUV.xy, _AI_TextureBias );
				output2 = SAMPLE_TEXTURE2D_BIAS( _Vertex, sampler_Vertex, frameUV.xy, _AI_TextureBias );
				output3 = SAMPLE_TEXTURE2D_BIAS( _Coord, sampler_Coord, frameUV.xy, _AI_TextureBias );
				output4 = SAMPLE_TEXTURE2D_BIAS( _FeatureA, sampler_FeatureA, frameUV.xy, _AI_TextureBias );
				#if ( defined(SHADERPASS) && ((defined(SHADERPASS_SHADOWS) && SHADERPASS == SHADERPASS_SHADOWS) || (defined(SHADERPASS_SHADOWCASTER) && SHADERPASS == SHADERPASS_SHADOWCASTER)) ) || defined(UNITY_PASS_SHADOWCASTER)
				viewPos.z += depth * _AI_ShadowView - _AI_ShadowBias;
				#else 
				viewPos.z += depth + _AI_ForwardBias;
				#endif
				positionWS = mul( UNITY_MATRIX_I_V, float4( viewPos.xyz, 1 ) ).xyz;
				#if defined(SHADERPASS) && defined(UNITY_PASS_SHADOWCASTER)
				#if _CASTING_PUNCTUAL_LIGHT_SHADOW
				float3 lightDirectionWS = normalize( _LightPosition - positionWS );
				#else
				float3 lightDirectionWS = _LightDirection;
				#endif
				positionCS = TransformWorldToHClip( ApplyShadowBias( positionWS, float3(0,0,0), lightDirectionWS ) );
				#if UNITY_REVERSED_Z
				positionCS.z = min( positionCS.z, positionCS.w * UNITY_NEAR_CLIP_VALUE );
				#else
				positionCS.z = max( positionCS.z, positionCS.w * UNITY_NEAR_CLIP_VALUE );
				#endif
				#else
				positionCS = mul( UNITY_MATRIX_P, float4( viewPos.xyz, 1 ) );
				#endif
			}
			
